# Environment Variables
# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hirehub_db?schema=public"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET="hirehub-jwt-access-secret-dev-key-2026"
JWT_REFRESH_SECRET="hirehub-jwt-refresh-secret-dev-key-2026"
JWT_EXPIRES_IN="15d"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV="development"

# ─── CORS ─────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"
